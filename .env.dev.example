# Hermes Development Stack — Environment Variables
# Copy this file to .env.dev, then fill in the values below.
#
# Usage:
#   make dev-up
#   make dev-check

# ── LiteLLM ────────────────────────────────────────────────────────────────
# Required: admin key used by all services to talk to LiteLLM.
# Must start with "sk-".
LITELLM_MASTER_KEY=sk-hermes-dev-change-me

# LiteLLM web UI credentials (http://localhost:4000/ui)
LITELLM_UI_USERNAME=admin
LITELLM_UI_PASSWORD=change-me

# ── Product API operator auth ───────────────────────────────────────────────
# The unified local dev stack enables an explicit local-only auth bypass by
# default so mutating product routes stay convenient while remaining clearly
# non-production. Set this to false and provide HERMES_API_KEY if you want to
# exercise the authenticated path locally.
HERMES_API_DEV_BYPASS_AUTH=true
HERMES_API_KEY=

# ── LLM provider keys ───────────────────────────────────────────────────────
# At least one provider is needed to run agents.

OPENAI_API_KEY=
# Optional extra keys for LiteLLM key-rotation
# OPENAI_API_KEY_1=
# OPENAI_API_KEY_2=

ANTHROPIC_API_KEY=
# ANTHROPIC_API_KEY_1=

GOOGLE_API_KEY=
# GEMINI_API_KEY=

# OpenRouter (alternative to direct provider keys)
# OPENROUTER_API_KEY=

# TradingView MCP project path (host)
TRADINGVIEW_MCP_DIR=/absolute/path/to/tradingview-mcp

# Local providers — point at a running LM Studio instance
# LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1
# Required when a profile uses `api_key_env: LM_STUDIO_API_KEY` for a local OpenAI-compatible endpoint.
# LM Studio commonly accepts any non-empty token, so `not-required` is a safe placeholder.
# LM_STUDIO_API_KEY=not-required

# ── Database ────────────────────────────────────────────────────────────────
# Defaults work out of the box. Change only if you have conflicts.
HERMES_TIMESCALE_DB=hermes_trading
HERMES_TIMESCALE_USER=hermes
HERMES_TIMESCALE_PASSWORD=hermes
# Host port for TimescaleDB (5433 avoids collisions with a local postgres on 5432)
HERMES_TIMESCALE_PORT=5433

# ── Redis ───────────────────────────────────────────────────────────────────
HERMES_REDIS_PORT=6379

# ── TradingView webhooks ────────────────────────────────────────────────────
# Set the same value in your TradingView alert webhook header.
TRADINGVIEW_WEBHOOK_SECRET=replace-with-shared-secret
TRADINGVIEW_WEBHOOK_SECRET_HEADER=X-TV-Secret

# ── Notification channels (all optional) ───────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=

# ── Exchange / paper trading ────────────────────────────────────────────────
# Use demo/testnet credentials only until live safeguards are complete.
BITMART_API_KEY=
BITMART_SECRET=
BITMART_MEMO=

# ── Live trading unlock (defaults stay paper) ───────────────────────────────
# Live trading requires all three controls below at the same time.
# 1. HERMES_TRADING_MODE=live
# 2. HERMES_ENABLE_LIVE_TRADING=true
# 3. HERMES_LIVE_TRADING_ACK exactly matches the acknowledgement phrase
HERMES_TRADING_MODE=paper
HERMES_PAPER_MODE=
HERMES_ENABLE_LIVE_TRADING=false
HERMES_LIVE_TRADING_ACK=

# ── Market data providers (all optional; degrade gracefully if absent) ──────
COINGECKO_API_KEY=
COINMARKETCAP_API_KEY=
TWELVEDATA_API_KEY=
CRYPTOPANIC_API_KEY=
NEWS_API_KEY=
LUNARCRUSH_API_KEY=
ETHERSCAN_API_KEY=
NANSEN_API_KEY=

# ── Service ports (override if defaults conflict with local ports) ──────────
LITELLM_PORT=4000
HERMES_DASHBOARD_PORT=9119
HERMES_API_PORT=8000
HERMES_WEB_PORT=3000
