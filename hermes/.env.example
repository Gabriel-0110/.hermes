APP_ENV=development
LOG_LEVEL=INFO
HERMES_API_BASE_URL=http://localhost:8000/api/v1

# Operator auth — mutating/operator endpoints fail closed unless either:
#   1. HERMES_API_KEY is set and callers use Authorization: Bearer <key>, or
#   2. HERMES_API_DEV_BYPASS_AUTH=true is set explicitly in local development.
# Recommended default outside the unified local dev stack: leave bypass false
# and set a strong random HERMES_API_KEY.
HERMES_API_KEY=
HERMES_API_DEV_BYPASS_AUTH=false

# Trading mode: "paper" (default) blocks live execution at the API layer.
# Only set to "live" when exchange credentials and risk controls are verified.
HERMES_TRADING_MODE=paper
HERMES_ENABLE_LIVE_TRADING=false
HERMES_LIVE_TRADING_ACK=
BITMART_API_KEY=
BITMART_SECRET=
BITMART_MEMO=
BITMART_UID=
BITMART_ACCOUNT_TYPE=swap
BITMART_MARGIN_MODE=cross
HERMES_BITMART_VERIFY_SIGNED_WRITES=false

OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

OLLAMA_BASE_URL=http://host.docker.internal:11434
LM_STUDIO_BASE_URL=http://host.docker.internal:1234

POSTGRES_USER=hermes
POSTGRES_PASSWORD=hermes
POSTGRES_DB=hermes
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://hermes:hermes@postgres:5432/hermes

TELEGRAM_BOT_TOKEN=your-telegram-bot-token
SLACK_BOT_TOKEN=your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
WEBHOOK_BASE_URL=http://localhost:8000
